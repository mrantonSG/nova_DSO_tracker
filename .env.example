# Nova DSO Tracker Environment Configuration
# Copy this file to instance/.env and configure as needed

# =============================================================================
# Required
# =============================================================================

# Flask session secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# =============================================================================
# Core Settings
# =============================================================================

# Single-user mode (True) or multi-user with authentication (False)
SINGLE_USER_MODE=True

# Sampling interval for astronomical calculations (minutes)
CALCULATION_PRECISION=15

# =============================================================================
# Multi-User Mode (only if SINGLE_USER_MODE=False)
# =============================================================================

# Comma-separated list of admin usernames
ADMIN_USERS=

# JWT secret key for SSO (generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET_KEY=

# =============================================================================
# Telemetry & Analytics
# =============================================================================

# Enable anonymous usage telemetry (true/false)
TELEMETRY_ENABLED=true

# Unique instance identifier (auto-generated on first run)
INSTANCE_ID=

# Telemetry endpoint URL
NOVA_TELEMETRY_ENDPOINT=

# Analytics dashboard access token (generate a random string)
# Access via: http://your-server/analytics?secret=YOUR_TOKEN
ANALYTICS_SECRET=

# Comma-separated usernames to exclude from analytics
ANALYTICS_EXCLUDE_USERS=

# =============================================================================
# External Services
# =============================================================================

# Nova catalog server URL
NOVA_CATALOG_URL=https://catalogs.nova-tracker.com

# DeepL API key for translations (optional)
DEEPL_API_KEY=

# Stellarium integration URL (optional)
STELLARIUM_API_URL_BASE=

# =============================================================================
# AI Configuration (optional - enables AI assistant features)
# =============================================================================

# AI provider: anthropic, openai, or other compatible providers
AI_PROVIDER=anthropic

# API key for the AI provider (required to enable AI features)
AI_API_KEY=

# Model to use for AI requests
AI_MODEL=claude-sonnet-4-20250514

# Custom base URL for AI API (optional, for self-hosted or proxy endpoints)
AI_BASE_URL=

# Comma-separated usernames allowed to use AI features (leave empty to disable)
AI_ALLOWED_USERS=

# =============================================================================
# Advanced / Internal
# =============================================================================

# Provisioning API key for automated setup
PROVISIONING_API_KEY=

# Custom state directory for telemetry
NOVA_STATE_DIR=
