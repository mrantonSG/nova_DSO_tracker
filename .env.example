# Nova DSO Tracker Environment Configuration
# Copy this file to instance/.env and configure as needed

# =============================================================================
# Required
# =============================================================================

# Flask session secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# =============================================================================
# Core Settings
# =============================================================================

# Single-user mode (True) or multi-user with authentication (False)
SINGLE_USER_MODE=True

# Sampling interval for astronomical calculations (minutes)
CALCULATION_PRECISION=15

# =============================================================================
# Multi-User Mode (only if SINGLE_USER_MODE=False)
# =============================================================================

# Comma-separated list of admin usernames
ADMIN_USERS=

# JWT secret key for SSO (generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET_KEY=

# =============================================================================
# Telemetry & Analytics
# =============================================================================

# Enable anonymous usage telemetry (true/false)
TELEMETRY_ENABLED=true

# Comma-separated usernames to exclude from analytics
ANALYTICS_EXCLUDE_USERS=

# =============================================================================
# External Services
# =============================================================================

# Nova catalog server URL
NOVA_CATALOG_URL=https://catalogs.nova-tracker.com

# =============================================================================
# AI Configuration (optional - enables AI assistant features)
# =============================================================================

# AI provider. Supported values:
#   anthropic         — Anthropic Claude models (recommended)
#   openai            — OpenAI models
#   openai-compatible — Any OpenAI-compatible provider (see examples below)
#   ollama            — Local Ollama instance (free, private)
AI_PROVIDER=anthropic

# API key for the chosen provider
AI_API_KEY=

# Model name (must match the provider's model identifier)
# Anthropic examples : claude-sonnet-4-20250514, claude-haiku-4-5-20251001
# OpenAI examples    : gpt-4o, gpt-4o-mini
# Z.AI examples      : glm-4.6, glm-4.7, glm-4.5-air
# MiniMax examples   : MiniMax-M2.5, MiniMax-M2.7
# Ollama examples    : llama3, mistral, qwen2.5
AI_MODEL=claude-sonnet-4-20250514

# Base URL — required for openai-compatible and ollama, ignored for anthropic/openai
# Z.AI (general)     : https://api.z.ai/api/paas/v4
# Z.AI (coding)      : https://api.z.ai/api/coding/paas/v4
# MiniMax            : https://api.minimax.io/v1
# Ollama (local)     : http://localhost:11434
AI_BASE_URL=

# Comma-separated usernames allowed to use AI features
# Use 'all' to grant access to all users
# Leave empty to disable AI for all users even if API key is set
AI_ALLOWED_USERS=

# =============================================================================
# Advanced / Internal
# =============================================================================

# Optional: Sentry error tracking DSN
SENTRY_DSN=
# Optional: Set to 1 to disable Flask debug mode
NOVA_NO_DEBUG=
# Optional: Override default instance directory path
INSTANCE_PATH=
# Optional: Custom error message for Stellarium integration
STELLARIUM_ERROR_MESSAGE=
