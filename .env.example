# Nova DSO Tracker - Environment Configuration
# Copy this file to .env and adjust values as needed.

# Set to False to enable multi-user mode (login, per-user data isolation)
SINGLE_USER_MODE=True

# Secret key for Flask sessions (REQUIRED for multi-user mode)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=
